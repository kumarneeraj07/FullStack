# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL) - Neon format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Seat lock time-to-live in seconds (how long a seat stays held before booking is confirmed)
SEAT_LOCK_TTL_SECONDS=300

# CORS - frontend origin
CLIENT_URL=http://localhost:5173
